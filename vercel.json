{
  "version": 2,
  "builds": [
    {
      "src": "api/ask.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/api/ask$",
      "dest": "/api/ask.js"
    },
    {
      "src": "^/frontend/?$",
      "dest": "/frontend/index.html"
    },
    {
      "src": "^/frontend/(.*)$",
      "dest": "/frontend/$1"
    },
    {
      "src": "^/$",
      "dest": "/frontend/index.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "/frontend/$1"
    }
  ]
}